# REST API base URL (no trailing slash, no /api suffix)
# Local:  http://localhost:3001
# Prod:   https://avyrix-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket base URL (optional — auto-derived from API URL if omitted)
# Local:  ws://localhost:3001
# Prod:   wss://avyrix-backend.onrender.com
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Stripe publishable key (optional — for billing page)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
