# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:3000
# Production (Vercel): https://avyrix.vercel.app

# OpenAI
OPENAI_API_KEY=

# Kling
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# HeyGen
HEYGEN_API_KEY=

# Cloudinary (primary storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Upstash Redis REST (optional — not used by Bull queues)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bull queue Redis (optional TCP URL — omit for in-process generation fallback)
REDIS_URL=
# UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# AWS S3 / R2 (optional — used when Cloudinary is not configured)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL_BASE=

# Admin
ADMIN_SECRET_KEY=
ADMIN_EMAIL=admin@avyrix.ai
ADMIN_PASSWORD=Admin@123456

# Seed (optional)
SEED_USER_PASSWORD=
