// AVYRIX AI — PostgreSQL schema (Section 5 handover)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum SubscriptionStatus {
  free
  active
  cancelled
  past_due
}

enum GenerationType {
  image
  video
}

enum GenerationStatus {
  queued
  processing
  completed
  failed
}

enum TransactionType {
  topup
  deduction
  refund
  purchase
  admin_adjustment
}

enum LogLevel {
  debug
  info
  warn
  error
}

model User {
  id                     String             @id @default(uuid())
  full_name              String
  email                  String             @unique
  password_hash          String
  role                   UserRole           @default(user)
  credit_balance         Int                @default(0)
  subscription_status    SubscriptionStatus @default(free)
  is_verified                   Boolean            @default(false)
  verification_token            String?
  verification_token_expires_at   DateTime?
  password_reset_token            String?
  refresh_token_hash              String?
  reset_token_expires_at          DateTime?
  stripe_customer_id     String?
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  projects              Project[]
  generations           Generation[]
  credit_transactions   CreditTransaction[] @relation("UserTransactions")
  subscriptions         Subscription[]
  admin_adjustments     CreditTransaction[] @relation("AdminCreatedTransactions")

  @@index([email])
  @@index([role])
  @@index([subscription_status])
  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  user_id     String
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([user_id])
  @@index([user_id, created_at])
  @@map("projects")
}

model Generation {
  id               String           @id @default(uuid())
  user_id          String
  project_id       String?
  type             GenerationType
  prompt           String
  parameters       Json             @default("{}")
  status           GenerationStatus @default(queued)
  api_provider     String?
  media_url        String?
  thumbnail_url    String?
  credits_used     Int                @default(0)
  credits_refunded Boolean            @default(false)
  error_message    String?
  duration_seconds Int?
  completed_at     DateTime?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt

  user                User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project             Project?            @relation(fields: [project_id], references: [id], onDelete: SetNull)
  credit_transactions CreditTransaction[]

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([user_id, status])
  @@index([user_id, type])
  @@index([project_id])
  @@index([status])
  @@index([created_at])
  @@map("generations")
}

model CreditTransaction {
  id            String          @id @default(uuid())
  user_id       String
  generation_id String?
  type          TransactionType
  amount        Int
  balance_after Int
  description   String
  created_by    String?
  created_at    DateTime        @default(now())

  user       User        @relation("UserTransactions", fields: [user_id], references: [id], onDelete: Cascade)
  generation Generation? @relation(fields: [generation_id], references: [id], onDelete: SetNull)
  admin      User?       @relation("AdminCreatedTransactions", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([generation_id])
  @@index([type])
  @@map("credit_transactions")
}

model Subscription {
  id                     String             @id @default(uuid())
  user_id                String
  stripe_subscription_id String             @unique
  stripe_price_id        String?
  status                 SubscriptionStatus @default(active)
  current_period_start   DateTime?
  current_period_end     DateTime?
  cancel_at_period_end   Boolean            @default(false)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@map("subscriptions")
}

model SystemLog {
  id         String   @id @default(uuid())
  level      LogLevel
  service    String
  message    String
  meta       Json?
  request_id String?
  user_id    String?
  created_at DateTime @default(now())

  @@index([created_at])
  @@index([level])
  @@index([service])
  @@index([service, created_at])
  @@map("system_logs")
}
